# ==========================================
# OMNI-MATCH A2A: ENVIRONMENT CONFIGURATION
# ==========================================

# 1. Google Gemini AI Configuration
# Get your free API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_ai_studio_key_here

# Keep this FALSE unless you are using an Enterprise Google Cloud Vertex AI account
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# 2. Security & Authentication
# Create your own random passwords/keys (comma separated) for local API security
API_KEYS=my-secret-key-1,my-secret-key-2

# 3. Agent URLs (For Local Testing & Webhooks)
# IMPORTANT: The healthcare agent needs a public URL so the external platform can connect to it. 
# Run 'ngrok http 8001' (or your port) and paste the HTTPS link here.
HEALTHCARE_AGENT_URL=https://your-custom-url.ngrok-free.dev

# Local URLs for internal services (Keep as localhost unless running in the cloud)
GENERAL_AGENT_URL=http://localhost:8002
ORCHESTRATOR_URL=http://localhost:8003

# 4. External Platform Integrations
# # The base URL of your Prompt Opinion workspace (applies to FHIR extensions).
PO_PLATFORM_BASE_URL=https://app.promptopinion.ai